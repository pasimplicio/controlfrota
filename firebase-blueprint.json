{
  "entities": {
    "User": {
      "title": "User",
      "description": "System user with role and permissions",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "name": { "type": "string" },
        "email": { "type": "string" },
        "role": { "type": "string", "enum": ["admin", "manager", "driver", "finance", "maintenance"] },
        "unit": { "type": "string" },
        "department": { "type": "string" },
        "status": { "type": "string", "enum": ["active", "inactive", "blocked"] },
        "cnh": { "type": "string" },
        "cnhCategory": { "type": "string" },
        "cnhExpiry": { "type": "string" }
      },
      "required": ["uid", "name", "email", "role", "status"]
    },
    "Vehicle": {
      "title": "Vehicle",
      "description": "Fleet vehicle details",
      "type": "object",
      "properties": {
        "plate": { "type": "string" },
        "renavam": { "type": "string" },
        "chassis": { "type": "string" },
        "brand": { "type": "string" },
        "model": { "type": "string" },
        "year": { "type": "number" },
        "color": { "type": "string" },
        "fuelType": { "type": "string" },
        "currentKm": { "type": "number" },
        "status": { "type": "string", "enum": ["active", "maintenance", "inactive", "reserved"] },
        "type": { "type": "string" },
        "category": { "type": "string" },
        "hierarchyLevel": { "type": "string" },
        "unit": { "type": "string" },
        "hasGps": { "type": "boolean" },
        "hasCamera": { "type": "boolean" },
        "photos": { "type": "array", "items": { "type": "string" } },
        "documents": {
          "type": "object",
          "properties": {
            "crlv": { "type": "string" },
            "insurance": { "type": "string" },
            "licensing": { "type": "string" }
          }
        }
      },
      "required": ["plate", "brand", "model", "status", "currentKm"]
    },
    "Reservation": {
      "title": "Reservation",
      "description": "Vehicle usage request",
      "type": "object",
      "properties": {
        "vehicleId": { "type": "string" },
        "driverId": { "type": "string" },
        "reason": { "type": "string" },
        "destination": { "type": "string" },
        "startDate": { "type": "string" },
        "endDate": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "approved", "rejected", "active", "completed"] },
        "approvedBy": { "type": "string" },
        "startKm": { "type": "number" },
        "endKm": { "type": "number" },
        "startFuel": { "type": "number" },
        "endFuel": { "type": "number" }
      },
      "required": ["vehicleId", "driverId", "startDate", "endDate", "status"]
    },
    "Maintenance": {
      "title": "Maintenance",
      "description": "Vehicle maintenance record",
      "type": "object",
      "properties": {
        "vehicleId": { "type": "string" },
        "osNumber": { "type": "string" },
        "priority": { "type": "string", "enum": ["low", "medium", "high", "critical"] },
        "type": { "type": "string", "enum": ["preventive", "corrective", "cleaning", "other"] },
        "status": { "type": "string", "enum": ["pending", "budgeting", "approved", "in-progress", "completed", "cancelled"] },
        "description": { "type": "string" },
        "scheduledDate": { "type": "string" },
        "completedDate": { "type": "string" },
        "cost": { "type": "number" },
        "kmAtMaintenance": { "type": "number" },
        "workshopId": { "type": "string" },
        "checkOutId": { "type": "string" },
        "checkInId": { "type": "string" },
        "documents": {
          "type": "object",
          "properties": {
            "os": { "type": "string" },
            "invoice": { "type": "string" },
            "other": { "type": "array", "items": { "type": "string" } }
          }
        },
        "notes": { "type": "string" },
        "createdAt": { "type": "string" },
        "updatedAt": { "type": "string" }
      },
      "required": ["vehicleId", "type", "date", "status", "priority"]
    },
    "Workshop": {
      "title": "Workshop",
      "description": "Maintenance service provider",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "cnpj": { "type": "string" },
        "phone": { "type": "string" },
        "email": { "type": "string" },
        "address": { "type": "string" },
        "city": { "type": "string" },
        "state": { "type": "string" },
        "specialties": { "type": "array", "items": { "type": "string" } },
        "status": { "type": "string", "enum": ["active", "inactive"] },
        "createdAt": { "type": "string" }
      },
      "required": ["name", "phone", "address", "status"]
    },
    "MaintenanceBudget": {
      "title": "MaintenanceBudget",
      "description": "Budget for a maintenance service",
      "type": "object",
      "properties": {
        "maintenanceId": { "type": "string" },
        "workshopId": { "type": "string" },
        "value": { "type": "number" },
        "description": { "type": "string" },
        "documentUrl": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "approved", "rejected"] },
        "approvedBy": { "type": "string" },
        "approvedAt": { "type": "string" },
        "createdAt": { "type": "string" }
      },
      "required": ["maintenanceId", "workshopId", "value", "status"]
    },
    "MaintenancePart": {
      "title": "MaintenancePart",
      "description": "Part used in maintenance",
      "type": "object",
      "properties": {
        "maintenanceId": { "type": "string" },
        "name": { "type": "string" },
        "quantity": { "type": "number" },
        "unitPrice": { "type": "number" },
        "totalPrice": { "type": "number" },
        "brand": { "type": "string" },
        "warrantyDays": { "type": "number" }
      },
      "required": ["maintenanceId", "name", "quantity", "unitPrice", "totalPrice"]
    },
    "Fueling": {
      "title": "Fueling",
      "description": "Fueling record",
      "type": "object",
      "properties": {
        "vehicleId": { "type": "string" },
        "driverId": { "type": "string" },
        "date": { "type": "string" },
        "km": { "type": "number" },
        "liters": { "type": "number" },
        "pricePerLiter": { "type": "number" },
        "totalValue": { "type": "number" },
        "stationName": { "type": "string" },
        "fuelType": { "type": "string" },
        "receiptPhoto": { "type": "string" },
        "location": {
          "type": "object",
          "properties": {
            "latitude": { "type": "number" },
            "longitude": { "type": "number" },
            "address": { "type": "string" }
          }
        },
        "consumption": { "type": "number" },
        "notes": { "type": "string" },
        "createdAt": { "type": "string" },
        "updatedAt": { "type": "string" }
      },
      "required": ["vehicleId", "driverId", "date", "km", "liters", "totalValue"]
    },
    "Unit": {
      "title": "Unit",
      "description": "Operational base or unit",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "address": { "type": "string" },
        "city": { "type": "string" },
        "state": { "type": "string" },
        "costCenter": { "type": "string" },
        "managerId": { "type": "string" },
        "departments": { "type": "array", "items": { "type": "string" } },
        "status": { "type": "string", "enum": ["active", "inactive"] }
      },
      "required": ["name", "address", "city", "state", "status"]
    },
    "Notification": {
      "title": "Notification",
      "description": "System notification for users",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "title": { "type": "string" },
        "message": { "type": "string" },
        "type": { "type": "string", "enum": ["info", "success", "warning", "error"] },
        "read": { "type": "boolean" },
        "createdAt": { "type": "string" },
        "link": { "type": "string" }
      },
      "required": ["userId", "title", "message", "type", "read", "createdAt"]
    },
    "Settings": {
      "title": "Settings",
      "description": "Global system settings",
      "type": "object",
      "properties": {
        "minAdvanceHours": { "type": "number" },
        "maxAdvanceDays": { "type": "number" },
        "allowWeekendReservations": { "type": "boolean" },
        "requireJustificationAboveHierarchy": { "type": "boolean" }
      }
    },
    "Inspection": {
      "title": "Inspection",
      "description": "Vehicle check-in/check-out inspection",
      "type": "object",
      "properties": {
        "reservationId": { "type": "string" },
        "vehicleId": { "type": "string" },
        "userId": { "type": "string" },
        "type": { "type": "string", "enum": ["check-out", "check-in"] },
        "km": { "type": "number" },
        "fuelLevel": { "type": "number" },
        "checklist": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "item": { "type": "string" },
              "status": { "type": "string", "enum": ["ok", "ruim", "na"] },
              "comment": { "type": "string" }
            }
          }
        },
        "damages": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "part": { "type": "string" },
              "description": { "type": "string" },
              "photoUrl": { "type": "string" }
            }
          }
        },
        "photos": { "type": "array", "items": { "type": "string" } },
        "notes": { "type": "string" },
        "createdAt": { "type": "string" }
      },
      "required": ["reservationId", "vehicleId", "userId", "type", "km", "fuelLevel", "createdAt"]
    }
  },
  "firestore": {
    "/users": { "schema": "User", "description": "System users" },
    "/vehicles": { "schema": "Vehicle", "description": "Fleet vehicles" },
    "/reservations": { "schema": "Reservation", "description": "Vehicle reservations" },
    "/maintenance": { "schema": "Maintenance", "description": "Maintenance logs" },
    "/workshops": { "schema": "Workshop", "description": "Maintenance workshops" },
    "/maintenance_budgets": { "schema": "MaintenanceBudget", "description": "Maintenance budgets" },
    "/maintenance_parts": { "schema": "MaintenancePart", "description": "Maintenance parts history" },
    "/fueling": { "schema": "Fueling", "description": "Fueling logs" },
    "/units": { "schema": "Unit", "description": "Operational units" },
    "/notifications": { "schema": "Notification", "description": "User notifications" },
    "/settings": { "schema": "Settings", "description": "System settings" },
    "/inspections": { "schema": "Inspection", "description": "Vehicle inspections" },
    "/system_config": { "schema": "object", "description": "Internal system configuration and maintenance flags" }
  }
}
