rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    // Collection: users
    // Fields: uid, name, email, role, unit, status
    //
    // Collection: vehicles
    // Fields: plate, brand, model, status, unit, currentKm
    //
    // Collection: reservations
    // Fields: vehicleId, driverId, status, startDate, endDate
    // ===============================================================

    // Helper Functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function getUserData() {
      let path = /databases/$(database)/documents/users/$(request.auth.uid);
      return exists(path) ? get(path).data : null;
    }

    function isAdmin() {
      let data = getUserData();
      return isAuthenticated() && (
        request.auth.token.email == 'pasimplicio@gmail.com' || 
        request.auth.token.email == 'admin@admin.com' ||
        (data != null && data.role == 'admin')
      );
    }

    function isManager() {
      let data = getUserData();
      return isAuthenticated() && data != null && data.role == 'manager';
    }

    function isDriver() {
      let data = getUserData();
      return isAuthenticated() && data != null && data.role == 'driver';
    }

    function isFinance() {
      let data = getUserData();
      return isAuthenticated() && data != null && data.role == 'finance';
    }

    function isMaintenance() {
      let data = getUserData();
      return isAuthenticated() && data != null && data.role == 'maintenance';
    }

    function belongsToUnit(unit) {
      let data = getUserData();
      return isAuthenticated() && data != null && data.unit == unit;
    }

    // Rules
    match /users/{userId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && request.auth.uid == userId;
      allow update: if isAdmin() || (isAuthenticated() && request.auth.uid == userId);
      allow delete: if isAdmin();
    }

    match /vehicles/{vehicleId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin() || isManager();
    }

    match /reservations/{resId} {
      // Relaxed read to allow Dashboard and Reservations list queries to work for all roles
      // Client-side filtering handles the view logic
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update: if isAdmin() || isManager() || 
        (isAuthenticated() && resource.data.driverId == request.auth.uid);
      allow delete: if isAdmin() || (isAuthenticated() && resource.data.driverId == request.auth.uid && resource.data.status == 'pending');
    }

    match /maintenance/{mId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin() || isManager() || isMaintenance();
    }

    match /fueling/{fId} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated();
    }

    match /units/{unitId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    match /notifications/{nId} {
      allow read: if isAuthenticated() && resource.data.userId == request.auth.uid;
      allow create: if isAuthenticated(); // Allow drivers to notify admins/managers
      allow update: if isAuthenticated() && resource.data.userId == request.auth.uid;
      allow delete: if isAuthenticated() && resource.data.userId == request.auth.uid;
    }

    match /settings/{configId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    match /inspections/{inspectionId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update: if isAdmin() || isManager();
      allow delete: if isAdmin();
    }

    match /system_config/{configId} {
      allow read, write: if isAdmin();
    }
  }
}
