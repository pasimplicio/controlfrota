rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    // Collection: users
    // Fields: uid, name, email, role, unit, status
    //
    // Collection: vehicles
    // Fields: plate, brand, model, status, unit, currentKm
    //
    // Collection: reservations
    // Fields: vehicleId, driverId, status, startDate, endDate
    // ===============================================================

    // Helper Functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function isAdmin() {
      return isAuthenticated() && (
        request.auth.token.email == 'pasimplicio@gmail.com' || 
        (request.auth.token.firebase.identities.email[0] == 'pasimplicio@gmail.com') ||
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin')
      );
    }

    function isManager() {
      return isAuthenticated() && 
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'manager';
    }

    function isDriver() {
      return isAuthenticated() && 
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'driver';
    }

    function belongsToUnit(unit) {
      return isAuthenticated() && 
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.unit == unit;
    }

    // Rules
    match /users/{userId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin() || (isAuthenticated() && (request.auth.uid == userId || request.auth.token.email == 'pasimplicio@gmail.com' || request.auth.token.firebase.identities.email[0] == 'pasimplicio@gmail.com'));
    }

    match /vehicles/{vehicleId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin() || isManager() || (isAuthenticated() && (request.auth.token.email == 'pasimplicio@gmail.com' || request.auth.token.firebase.identities.email[0] == 'pasimplicio@gmail.com'));
    }

    match /reservations/{resId} {
      allow read: if isAdmin() || isManager() || (isAuthenticated() && (resource.data.driverId == request.auth.uid || belongsToUnit(resource.data.unit)));
      allow create: if isAuthenticated() && request.resource.data.status == 'pending';
      allow update: if isAdmin() || isManager() || (isAuthenticated() && resource.data.driverId == request.auth.uid && request.resource.data.status == resource.data.status);
      allow delete: if isAdmin() || isManager() || (isAuthenticated() && resource.data.driverId == request.auth.uid);
    }

    match /maintenance/{mId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin() || isManager() || 
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'maintenance');
    }

    match /fueling/{fId} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated();
    }

    match /units/{unitId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin() || isManager() || (isAuthenticated() && (request.auth.token.email == 'pasimplicio@gmail.com' || request.auth.token.firebase.identities.email[0] == 'pasimplicio@gmail.com'));
    }

    match /system_config/{configId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }
  }
}
